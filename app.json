{
  "expo": {
    "name": "StudyMate AI",
    "slug": "studymate-ai",
    "owner": "hiltonmans-team",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "studymate",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#6366F1"
      },
      "package": "com.hiltonmans.studymateai"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hiltonmans.studymateai"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
